# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/tea_guard

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-32-char-random-string
# python -c "import secrets; print(secrets.token_hex(32))"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AWS / S3 (LocalStack in development) ─────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_ENDPOINT_URL=http://localstack:4566   # leave blank in production (real AWS)

S3_RAW_UPLOADS_BUCKET=raw-uploads
S3_PROCESSED_BUCKET=processed-outputs
S3_MODEL_BUCKET=model-artifacts

# ── Admin Dashboard ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@tea.lk
ADMIN_PASSWORD=set-a-secure-password-before-deploy

# ── Service URLs ──────────────────────────────────────────────────────────────
BACKEND_URL=http://backend:8000

# ── Runtime ──────────────────────────────────────────────────────────────────
ENV=development
# Set ENV=production on deploy — disables debug, enforces HTTPS, hides stack traces

# ── ML Model Artifacts ────────────────────────────────────────────────────────
# After training notebooks in /ml_training/, copy artifacts to:
#   backend/app/ml/model_artifacts/
# Or upload to the model-artifacts S3 bucket.
# MODEL_ARTIFACTS_PATH=/app/ml/model_artifacts  (default in backend)
